{
  "expo": {
    "name": "Resibo",
    "slug": "resibo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/resibo-icon.png",
    "splash": {
      "image": "./assets/resibo-mascot.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E293B"
